module str = "std/strings"
module panics = "std/panics"


int@ numbers

func pushNumber(int number) do
  int size = len:numbers
  resize:(numbers, size + 1)
  numbers[size] = number
end

func int popNumber() do
  int size = len:numbers
  if size == 0 do panic:(panics.userError, "") end
  int result = numbers[size - 1]
  resize:(numbers, size - 1)
  return result
end

func parse(string text) do
  int pos = 0
  int len = str.strLen(text)

  while pos < len do
    char ch = text[pos]

    if ch == ' ' do
      while ch == ' ' do
        pos = pos + 1
        ch = text[pos]
      end

    elif str.find(str.digits, ch) != -1 do
      string number

      while str.find(str.digits, ch) != -1 do
        int size = len:(number)
        resize:(number, size + 1)
        number[size] = ch
        pos = pos + 1
        ch = text[pos]
      end

      pushNumber(str.parseInt(number))

    elif str.find(v"+-*/", ch) != -1 do
      pos = pos + 1
      int b = popNumber()
      int a = popNumber()

      if   ch == '+' do pushNumber(a + b)
      elif ch == '-' do pushNumber(a - b)
      elif ch == '*' do pushNumber(a * b)
      elif ch == '/' do 
        if b == 0 do panic:(panics.zeroDivision, "zeroDivision")
        else do pushNumber(a / b)
        end
      end

    else do
      panic:(panics.valueError, fmt:("Invalid character: '", ch, "' at pos ", pos))
    end
  end
end

parse(v"10 4 + 2 * 7 / 3 -")
print: fmt: numbers[0]